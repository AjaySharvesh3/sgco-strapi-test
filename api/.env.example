# Copy to .env and edit values.

# Base URLs
STRAPI_API_URL=http://localhost:1337
NEXT_APP_API_URL=http://localhost:3000/api

# Strapi Full-Access API token.
# Create in admin: Settings → API Tokens → Create new API Token (Full access, Unlimited).
# When set, all Strapi requests in the tests send Authorization: Bearer <token>,
# which bypasses the Public-role permission checks entirely.
# Leave blank to call anonymously (requires Public role permissions).
STRAPI_API_TOKEN=

# A course (product) id that exists in Strapi — required for the buy-course test.
# You can grab one from the admin panel or from GET {STRAPI_API_URL}/api/courses.
TEST_COURSE_ID=1
TEST_COURSE_FEE=10

# Authorize.Net sandbox test card (works with the sandbox gateway)
TEST_CARD_NUMBER=4111111111111111
TEST_CARD_EXP_MONTH=12
TEST_CARD_EXP_YEAR=2034
TEST_CARD_CVV=123
TEST_ZIP_CODE=10001
